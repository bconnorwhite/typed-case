{
  "name": "typed-case",
  "version": "2.0.0",
  "description": "Convert between typesafe string casings",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "Connor White",
    "email": "oss@bconnorwhite.com",
    "url": "https://bconnorwhite.com"
  },
  "homepage": "https://github.bconnorwhite.com/typed-case#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bconnorwhite/typed-case.git"
  },
  "bugs": "https://github.com/bconnorwhite/typed-case/issues",
  "keywords": [
    "case",
    "type",
    "safe",
    "to",
    "pascal",
    "snake",
    "camel",
    "kebab",
    "ts",
    "types"
  ],
  "type": "module",
  "main": "./build/index.js",
  "exports": {
    ".": "./build/index.js"
  },
  "types": "./build/index.d.ts",
  "files": [
    "build/**/!(tsconfig.tsbuildinfo)"
  ],
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --project ./tsconfig.json",
    "coverage": "vitest run --config ./vitest.config.mjs --project node --coverage",
    "lint": "npm run lint:package && npm run lint:source",
    "lint:package": "npmPkgJsonLint .",
    "lint:source": "ESLINT_USE_FLAT_CONFIG=false eslint src test test-d --ext .ts",
    "prepack": "npm run build",
    "release": "npm publish",
    "test": "npm run test:node && npm run test:browser && npm run test:bun",
    "test:browser": "vitest run --config ./vitest.config.mjs --project browser",
    "test:bun": "bun test ./test/*.test.ts",
    "test:node": "vitest run --config ./vitest.config.mjs --project node",
    "typecheck": "npm run build && tsc --project ./test/tsconfig.json && tsc --project ./test-d/tsconfig.json && tsc --project ./test-d-nonstrict/tsconfig.json && tsd"
  },
  "devDependencies": {
    "@bconnorwhite/eslint-config": "^1.1.0",
    "@bconnorwhite/tsconfig": "^1.0.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-json": "^4.0.1",
    "npm-package-json-lint": "^9.1.0",
    "npm-package-json-lint-config-bconnorwhite": "^1.0.0",
    "playwright": "^1.58.2",
    "tsd": "^0.31.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "eslintConfig": {
    "extends": "@bconnorwhite/eslint-config"
  },
  "npmpackagejsonlint": {
    "extends": "npm-package-json-lint-config-bconnorwhite/oss"
  }
}
